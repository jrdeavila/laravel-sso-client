{
    "name": "camara-de-comercio-de-valledupar/laravel-sso-client",
    "description": "SSO client package for Laravel receiver applications (Cámara de Comercio de Valledupar)",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "CamaradeComercioDeValledupar\\SsoClient\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CamaradeComercioDeValledupar\\SsoClient\\SsoClientServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "version": "1.2.0"
}